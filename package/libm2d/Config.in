comment "libm2d requires a GPU strategy"
	depends on BR2_MCHP_SAM_NO_GPU

config BR2_PACKAGE_LIBM2D
	bool "libm2d"
	depends on BR2_MCHP_SAM_HAS_GPU2D
	depends on !BR2_MCHP_SAM_NO_GPU
	select BR2_PACKAGE_LIBDRM if (BR2_MCHP_SAM_SAM9X6_GFX2D || BR2_MCHP_SAM_SAM9X7_GFX2D || BR2_MCHP_SAM_GC520UL_ETNAVIV)
	select BR2_PACKAGE_LIBDRM_ETNAVIV if BR2_MCHP_SAM_GC520UL_ETNAVIV
	select BR2_PACKAGE_NANO2D if BR2_MCHP_SAM_GC520UL_NANO2D
	help
	  libm2d is a library that provides the Multi 2D Graphics API.

if BR2_PACKAGE_LIBM2D
config BR2_PACKAGE_LIBM2D_TESTS
	bool "Build tests"
	default y
	help
	  If unsure, say Y.

endif
